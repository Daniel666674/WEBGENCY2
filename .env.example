# Auto-CRM - Variables de Entorno
# Copia este archivo como .env.local: cp .env.example .env.local

# =============================================================================
# OPCIONAL: API de Claude para clasificacion de leads con IA
# Si no se configura, el CRM usa scoring basado en reglas (funciona igual de bien)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPCIONAL: Email digest diario (registrate gratis en resend.com)
# =============================================================================
# RESEND_API_KEY=re_...
# DIGEST_EMAIL=tu@email.com
# DIGEST_FROM=Auto-CRM <onboarding@resend.dev>

# =============================================================================
# LOGIN CON GOOGLE (Auth.js) — desactivado hasta que se configure
# Deja AUTH_ENABLED sin definir (o en "false") para seguir usando el CRM
# sin login, como hasta ahora. Solo ponlo en "true" cuando ya tengas
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET reales de Google Cloud Console.
# =============================================================================
# AUTH_ENABLED=true
# AUTH_SECRET=                      # genera con: npx auth secret
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_EMAILS=tu@dominio.com,socio@dominio.com   # unicas 2 cuentas permitidas
