# Auto-CRM - Variables de Entorno
# Copia este archivo como .env.local: cp .env.example .env.local

# =============================================================================
# OPCIONAL: API de Claude para clasificacion de leads con IA
# Si no se configura, el CRM usa scoring basado en reglas (funciona igual de bien)
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPCIONAL: Email digest diario — dos opciones gratis, usa una:
#
# Opcion A — Gmail (sin Google Cloud Console): activa Verificacion en 2 pasos
# en tu cuenta, genera un "App password" (Google Account > Seguridad >
# App passwords) y ponlo aqui:
# =============================================================================
# GMAIL_USER=tu@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
#
# Opcion B — Resend (registrate gratis en resend.com):
# RESEND_API_KEY=re_...
# DIGEST_FROM=Auto-CRM <onboarding@resend.dev>
#
# Con cualquiera de las dos:
# DIGEST_EMAIL=tu@email.com          # si falta, usa GMAIL_USER

# =============================================================================
# REQUERIDO: login con usuario y contraseña
# Sin esto el CRM queda cerrado (falla cerrado, no abierto) — la pantalla de
# login pide estas credenciales antes de dejar entrar a cualquier pagina.
# SESSION_SECRET firma la cookie de sesion para que no se pueda falsificar
# con una simple peticion HTTP; genera cualquier string largo aleatorio,
# por ejemplo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================================================
# CRM_USERNAME=
# CRM_PASSWORD=
# SESSION_SECRET=

# =============================================================================
# OPCIONAL: LOGIN CON GOOGLE (Auth.js) — reemplaza el usuario/contraseña de
# arriba cuando esté listo. Solo ponlo en "true" cuando ya tengas
# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET reales de Google Cloud Console.
# =============================================================================
# AUTH_ENABLED=true
# AUTH_SECRET=                      # genera con: npx auth secret
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_EMAILS=tu@dominio.com,socio@dominio.com   # unicas 2 cuentas permitidas

# =============================================================================
# OPCIONAL (recomendado): analiticas en vivo del cliente (GA4 + Search Console)
# via CUENTA DE SERVICIO — no requiere AUTH_ENABLED ni iniciar sesion con Google.
#
# 1. En Google Cloud, crea una cuenta de servicio y descarga su clave JSON.
# 2. Habilita "Google Analytics Data API" y "Search Console API" en el proyecto.
# 3. En GA4 (Admin > Property Access) agrega el email de la cuenta de servicio
#    (…@….iam.gserviceaccount.com) como Viewer/Analyst de la propiedad.
# 4. En Search Console (Settings > Users) agrega ese mismo email como usuario.
# 5. Pega TODO el JSON de la clave aqui en una sola linea:
# =============================================================================
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...", ...}

# =============================================================================
# OPCIONAL: cobro automatico de mensualidad + confirmacion por WhatsApp
# La pasarela (Wompi/Bold/PayU) y el token de WhatsApp se configuran desde
# Settings > Automatizaciones, no aqui. Este es el unico secreto que si va
# en .env: protege POST /api/payments/check-standing, la ruta que dispara el
# cron cada hora (no tiene sesion de navegador que la proteja).
# =============================================================================
# CRON_SECRET=                      # genera cualquier string largo aleatorio
# CRM_BASE_URL=http://localhost:3000  # solo si el CRM no corre en localhost:3000

# =============================================================================
# SOLO PARA EL DEMO EN VERCEL: persistencia de datos
# En Vercel el archivo SQLite vive en /tmp y se borra en cada cold start —
# sin esto, todo lo que agregues en el demo desaparece. Para activarlo:
# Vercel Dashboard > Storage > Create Blob store > conectar al proyecto.
# El token se inyecta automaticamente como env var; no hay que pegarlo a mano.
# Localmente no hace falta nada — el CRM guarda en data/crm.db como siempre.
# =============================================================================
# BLOB_READ_WRITE_TOKEN=
